  "env": {
    "XAI_API_KEY": "HIER_XAI_KEY_EINSETZEN",
    "OPENAI_API_KEY": "HIER_OPENAI_KEY_EINSETZEN"
  },
  "hooks": {
    "UserPromptSubmit": [
      {
        "hooks": [
          {
